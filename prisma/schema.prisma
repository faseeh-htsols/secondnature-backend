// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/**
 * ========================= Enums =========================
 */
enum Role {
  SUPER_ADMIN
  ADMIN
}

/**
 * ========================= Core Models =========================
 */
model Users {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  username           String    @unique @db.VarChar(255)
  password           String    @db.VarChar(300)
  role               Role
  is_active          Boolean   @default(true)
  reset_token        String?   @db.VarChar(500)
  reset_token_expiry DateTime?
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @updatedAt @db.Timestamp(0)

  @@map("users")
}

model Author {
  id         Int      @id @default(autoincrement())
  name       String
  pictureUrl String
  bio        String   @db.VarChar(500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  blogs Blog[]

  @@map("author")
}

model Blog {
  id                Int       @id @default(autoincrement())
  title             String
  description       String    @db.Text
  pictureUrl        String
  slug              String    @unique
  authorId          Int
  publishedDate     DateTime?
  scheduledDate     DateTime?
  isPublished       Boolean   @default(false)
  shouldAutoPublish Boolean   @default(true)
  contentJson       Json      @db.Json
  contentHtml       String?   @db.MediumText
  faqs              Json?     @db.Json
  wordCount         Int?      @default(0)
  readingTimeMin    Int?      @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  author   Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  seo      BlogSEO?
  blogTags BlogTag[]
  blogCTAs BlogCTA[]

  @@index([authorId])
  @@index([isPublished, publishedDate])
  @@index([scheduledDate])
  @@fulltext([title, contentHtml])
  @@map("blog")
}

/**
 * ========================= SEO (per-blog) =========================
 */
model BlogSEO {
  id             Int      @id @default(autoincrement())
  blogId         Int      @unique
  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.VarChar(500)
  seoImageAlt    String?  @db.VarChar(255)
  schemaJson     Json?    @db.Json
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId], map: "blogseo_blogId_idx")
  @@map("blog_seo")
}

/**
 * ========================= Tags =========================
 */
model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogTags BlogTag[]

  @@map("tag")
}

model BlogTag {
  id        Int      @id @default(autoincrement())
  blogId    Int
  tagId     Int
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([blogId, tagId])
  @@index([blogId])
  @@index([tagId])
  @@map("blog_tag")
}

/**
 * ========================= CTAs (Call-to-Actions) =========================
 */
model CTA {
  id         Int      @id @default(autoincrement())
  imageUrl   String?
  heading    String?  @db.VarChar(255)
  paragraph  String?  @db.Text
  buttonText String   @db.VarChar(100)
  buttonHref String   @db.VarChar(500)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  blogCTAs BlogCTA[]

  @@map("cta")
}

model BlogCTA {
  id           Int      @id @default(autoincrement())
  blogId       Int
  ctaId        Int
  sectionIndex Int      @default(0)
  createdAt    DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  cta  CTA  @relation(fields: [ctaId], references: [id], onDelete: Cascade)

  @@unique([blogId, ctaId, sectionIndex])
  @@index([blogId])
  @@index([ctaId])
  @@map("blog_cta")
}
