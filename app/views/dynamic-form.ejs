<!DOCTYPE html>
<html data-editor-version="2" class="sg-campaigns">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=Edge" />
    <title><%= subject || "New Website Enquiry" %></title>

    <style type="text/css">
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f5f5f5;
      }

      .container {
        max-width: 600px;
        margin: 8px auto;
        padding: 20px;
        background-color: #ffffff !important;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }

      .logo {
        text-align: center;
        margin-bottom: 20px;
        border-bottom: 3px solid #e8ecef;
        background-color: #000000;
        padding: 20px;
        border-radius: 10px;
      }

      .logo img {
        max-width: 200px;
        height: auto;
      }

      .invitation-message {
        margin-bottom: 20px;
        padding: 10px;
        border-radius: 10px;
      }

      p {
        font-size: 16px;
        line-height: 24px;
        margin: 0 0 12px;
      }

      .bold-text {
        font-weight: 600;
      }

      .text-color {
        color: #636571;
      }

      .field-row {
        margin-bottom: 10px;
      }

      .message-box {
        padding: 12px;
        border-left: 4px solid #d0d0d0;
        font-style: italic;
        background-color: #fafafa;
        border-radius: 6px;
        white-space: pre-wrap;
      }

      .meta-box {
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #e8ecef;
      }

      .meta-box p {
        font-size: 14px;
        line-height: 20px;
        color: #636571;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="logo">
        <img
          src="<%= logoUrl || 'https://second-nature-tau.vercel.app/flower-logo.svg' %>"
          alt="Second Nature Logo"
        />
      </div>

      <div class="invitation-message">
        <p class="text-color bold-text">
          Dear <%= recipientName || "Team" %>,
        </p>

        <p>
          <%= introText || "You have received a new enquiry from the website." %>
        </p>

        <% if (fields && fields.length) { %>
          <% fields.forEach((field) => { %>
            <% if (field.label && field.value && field.label.toLowerCase() !== 'message') { %>
              <p class="field-row">
                <span class="bold-text"><%= field.label %>:</span>
                <%= field.value %>
              </p>
            <% } %>
          <% }) %>
        <% } %>

        <% 
          const messageField = fields && fields.find(
            (field) => field.label && field.label.toLowerCase() === "message"
          );
        %>

        <% if (messageField && messageField.value) { %>
          <p><span class="bold-text">Message:</span></p>
          <p class="message-box"><%= messageField.value %></p>
        <% } %>

        <div class="meta-box">
          <% if (formType) { %>
            <p><span class="bold-text">Form Type:</span> <%= formType %></p>
          <% } %>

          <% if (page) { %>
            <p><span class="bold-text">Page:</span> <%= page %></p>
          <% } %>

          <% if (submittedAt) { %>
            <p><span class="bold-text">Submitted At:</span> <%= submittedAt %></p>
          <% } %>
        </div>

        <p class="text-color bold-text" style="margin-top: 20px;">Thank you</p>
      </div>
    </div>
  </body>
</html>