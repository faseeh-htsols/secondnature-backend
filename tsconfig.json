{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./app",
    "outDir": "./build",
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["app/**/*.ts"],
  "exclude": ["node_modules", "build"]
}